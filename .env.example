# Copia este archivo como .env y completa solo lo que necesites.

# NASA FIRMS requiere MAP_KEY gratuito:
# https://firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_MAP_KEY=TU_MAP_KEY_AQUI

# OpenSky funciona anonimo, pero OAuth2 da mas cuota.
# Crea un API client en tu cuenta OpenSky si quieres autenticarte.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ACLED requiere acceso myACLED. Puedes usar un token directo o usuario/password OAuth.
# https://acleddata.com/api-documentation/getting-started
ACLED_API_KEY=
ACLED_USERNAME=
ACLED_PASSWORD=
ACLED_DAYS=90
ACLED_LIMIT=500
ACLED_COUNTRIES=Iran;Israel;Palestine;Lebanon;Syria;Iraq;Yemen;Saudi Arabia;United Arab Emirates;Qatar;Oman;Bahrain;Kuwait
ACLED_KEYWORDS=Iran;Israel;Middle East;Red Sea;Gulf

# WorldPop API / datos poblacionales. ISO3 separados por punto y coma.
WORLDPOP_DATASET=wpgp
WORLDPOP_YEAR=2020
WORLDPOP_COUNTRIES=IRN;ISR;PSE;LBN;SYR;IRQ;YEM
WORLDPOP_MIN_INTERVAL_SECONDS=2

# UNHCR Refugee Data Finder API. Usa ISO3 de origen/asilo regional.
UNHCR_YEAR=2025
UNHCR_COUNTRIES=IRN;ISR;PSE;LBN;SYR;IRQ;YEM

# HDX usa CKAN package_search publico para datasets humanitarios.
HDX_QUERIES=Middle East hospitals;Iran infrastructure;Israel infrastructure;Palestine humanitarian access;Lebanon roads;Syria camps;Yemen humanitarian corridors
HDX_ROWS=10
HDX_MIN_INTERVAL_SECONDS=2

# Sentinel Hub requiere OAuth client credentials.
# https://www.sentinel-hub.com/
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
SENTINEL_HUB_COLLECTION=sentinel-2-l2a
# west,south,east,north
SENTINEL_HUB_BBOX=34,24,64,40
SENTINEL_HUB_DAYS=30
SENTINEL_HUB_LIMIT=50

# OpenStreetMap / Overpass. Bbox: lat_min,lon_min,lat_max,lon_max.
OSM_BBOX=24,34,40,64
OSM_OVERPASS_URLS=https://overpass-api.de/api/interpreter;https://overpass.kumi.systems/api/interpreter
OSM_MIN_INTERVAL_SECONDS=5

# Google Earth Engine queda deshabilitado por defecto porque requiere auth local.
# Instala earthengine-api y ejecuta earthengine authenticate antes de habilitarlo.
GEE_PROJECT=
GEE_COLLECTION=COPERNICUS/S2_SR_HARMONIZED
# west,south,east,north
GEE_BBOX=34,24,64,40
GEE_DAYS=30

# UKMTO se consume desde reportes publicos. pypdf permite leer los boletines PDF.
# https://www.ukmto.org/ukmto-products/warnings
UKMTO_MAX_REPORTS=25
UKMTO_PAGES=https://www.ukmto.org/recent-incidents;https://www.ukmto.org/ukmto-products/warnings;https://www.ukmto.org/ukmto-products/advisories

# Bluesky usa AppView publico; las credenciales son opcionales para mejor cuota.
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
BLUESKY_QUERIES=Iran Israel;missiles Iran Israel;Red Sea attacks;Gaza escalation;Middle East escalation
BLUESKY_LIMIT=50
BLUESKY_DAYS=14

# YouTube Data API v3 requiere API key.
YOUTUBE_API_KEY=
YOUTUBE_QUERIES=geopolitical analysis Iran Israel conflict;Iran Israel OSINT;Red Sea attacks;Middle East escalation;Iran Israel missiles analysis
YOUTUBE_MAX_RESULTS=25
YOUTUBE_DAYS=30

# Fuentes disponibles:
# gdelt,bbc_rss,aljazeera_rss,google_news_rss,opensky,nasa_firms,acled,worldpop,unhcr,hdx,sentinel_hub,openstreetmap,google_earth_engine,ukmto,bluesky,youtube
ENABLED_SOURCES=gdelt,bbc_rss,aljazeera_rss,google_news_rss,opensky,nasa_firms,acled,worldpop,unhcr,hdx,sentinel_hub,openstreetmap,ukmto,bluesky,youtube

# Para pruebas con GDELT rate-limited, puedes desactivar temporalmente:
# DISABLED_SOURCES=gdelt

DATA_DIR=data
USE_CACHE=true
CACHE_TTL_MINUTES=60
REQUEST_TIMEOUT=30
MAX_RETRIES=4
BACKOFF_FACTOR=2
BACKOFF_MAX_SECONDS=300
# BACKOFF_MAX_SECONDS limita solo el backoff calculado; si un servidor manda
# Retry-After, el pipeline respeta esa espera.

# GDELT: 100 aumenta cobertura sin hacer muchas llamadas.
# El pipeline conserva cache, User-Agent, sleep local, backoff y Retry-After.
GDELT_TIMESPAN=24h
GDELT_MAXRECORDS=100
GDELT_SORT=datedesc
GDELT_MIN_INTERVAL_SECONDS=30
USER_AGENT=ProyectoFinalML1-OSINTPipeline/1.0 (academic research; contact: estudiante-universidad@example.com)

# Runtime local: caches dentro del proyecto para evitar errores de permisos.
PYTHONPATH=.
MPLCONFIGDIR=.cache/matplotlib
MPLBACKEND=Agg
NLTK_DATA=.cache/nltk
HF_HOME=.cache/huggingface
TRANSFORMERS_CACHE=.cache/huggingface/transformers
SENTENCE_TRANSFORMERS_HOME=.cache/sentence_transformers
TOKENIZERS_PARALLELISM=false
LOKY_MAX_CPU_COUNT=8

# Google News RSS: queries tematicas separadas por punto y coma.
GOOGLE_NEWS_QUERIES=Iran Israel conflict;Iran Israel escalation;Iran US Israel Middle East
GOOGLE_NEWS_HL=en-US
GOOGLE_NEWS_GL=US
GOOGLE_NEWS_CEID=US:en
GOOGLE_NEWS_MIN_INTERVAL_SECONDS=5

# OpenSky bbox: lat_min,lon_min,lat_max,lon_max
OPENSKY_BBOX=24,34,40,64

# NASA FIRMS area: west,south,east,north.
# Mantener Medio Oriente ampliado; no usar bbox mundial en el dataset final.
NASA_FIRMS_SOURCE=VIIRS_SNPP_NRT
NASA_FIRMS_AREA=20,10,80,50
NASA_FIRMS_DAY_RANGE=7
# Si NASA rechaza 7/14 por limite vigente del API, el pipeline prueba el maximo permitido informado.
NASA_FIRMS_EMPTY_RETRY_DAY_RANGE=14
# NASA_FIRMS_DATE=2026-05-12
